Options -MultiViews
RewriteEngine On
RewriteBase /

# API, admin, sanctum → Laravel
RewriteCond %{REQUEST_URI} ^/(api|admin|sanctum)(/|$)
RewriteRule ^(.*)$ backend/public/index.php [L]

# Статические файлы отдаём как есть
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# SPA fallback — все остальные пути → Nuxt
RewriteRule ^(.*)$ /200.html [L]
